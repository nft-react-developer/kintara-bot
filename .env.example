# ============================================================
#  KINTARA BOT — konfigurasi (.env)
#  Cukup isi 2 field WAJIB di bawah. Sisanya opsional (ada default).
#  JANGAN commit file .env asli — sudah di-.gitignore.
# ============================================================

# ===== WAJIB =====
# 1) Solana wallet private key (base58). Bot login OTOMATIS pakai ini
#    (tanda-tangan challenge). TIDAK perlu cookie/session manual.
WALLET_PRIVATE_KEY=

# 2) Telegram bot token dari @BotFather (format 1234567890:AAxxxxxxxx)
TELEGRAM_BOT_TOKEN=

# ===== OPSIONAL =====
# Chat ID Telegram kamu. Kosongkan -> auto-capture saat kamu kirim /start ke bot.
TELEGRAM_CHAT_ID=

# Shard/server game (default s2). Ganti kalau mau server lain (s1..s12).
KINTARA_SHARD=s2

# API hosts (default sudah benar, jarang diubah).
KINTARA_API_BASE=https://kintara.gg
KINTARA_FANOUT_BASE=https://ktra-server-b.onrender.com
