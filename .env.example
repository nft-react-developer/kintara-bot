# ============================================================
#  KINTARA BOT — configuration (.env)
#  Fill in the 2 REQUIRED fields below. The rest are optional (have defaults).
#  NEVER commit your real .env file — it is already git-ignored.
# ============================================================

# ===== REQUIRED =====
# 1) Solana wallet private key (base58). The bot logs in AUTOMATICALLY with this
#    (signs the auth challenge). No cookie/session needed.
WALLET_PRIVATE_KEY=

# 2) Telegram bot token from @BotFather (format 1234567890:AAxxxxxxxx)
TELEGRAM_BOT_TOKEN=

# ===== OPTIONAL =====
# Your Telegram chat ID. Leave empty -> auto-captured when you send /start to the bot.
TELEGRAM_CHAT_ID=

# Game shard/server. Servers s1-s3 are membership/level-gated; the bot auto-picks
# the lowest-queue OPEN server (s4+) via a live gate-check, so this is just a
# fallback default. (s1..s12)
KINTARA_SHARD=s4

# Lowest shard the auto-picker is allowed to choose (default 4). Accounts below
# level 20 / without Kintara Club membership can't enter s1-s3, so the picker
# never even probes them. Lower this only if you have access.
KINTARA_MIN_SHARD=4

# Servers s1-s3 are membership/level-gated (Kintara Club, or character level 20+).
# The bot auto-skips them. Once you reach level 20 (or buy premium access), set
# this to 1 to ignore the floor + gate-check and allow joining s1-s3 as well.
KINTARA_ALLOW_LOW_SERVERS=0

# API hosts (defaults are correct, rarely changed).
KINTARA_API_BASE=https://kintara.gg
KINTARA_FANOUT_BASE=https://ktra-server-b.onrender.com

# Combat supplies
COMBAT_MIN_GOLD=20
COMBAT_MIN_HEALTH_POTIONS=6
COMBAT_MIN_SHIELD_POTIONS=2
