# ============================================================
#  KINTARA BOT — configuration (.env)
#  Fill in the 2 REQUIRED fields below. The rest are optional (have defaults).
#  NEVER commit your real .env file — it is already git-ignored.
# ============================================================

# ===== REQUIRED =====
# 1) Solana wallet private key (base58). The bot logs in AUTOMATICALLY with this
#    (signs the auth challenge). No cookie/session needed.
WALLET_PRIVATE_KEY=

# 2) Telegram bot token from @BotFather (format 1234567890:AAxxxxxxxx)
TELEGRAM_BOT_TOKEN=

# ===== OPTIONAL =====
# Your Telegram chat ID. Leave empty -> auto-captured when you send /start to the bot.
TELEGRAM_CHAT_ID=

# Game shard/server (default s2). Change for a different server (s1..s12).
KINTARA_SHARD=s2
# If a shard rejects queue/presence with HTTP 403, try these shards in order.
KINTARA_SHARD_FALLBACKS=s1,s3,s4,s5,s6,s7,s8,s9,s10,s11,s12

# API hosts (defaults are correct, rarely changed).
KINTARA_API_BASE=https://kintara.gg
KINTARA_FANOUT_BASE=https://ktra-server-b.onrender.com

# Optional Express HTTP server. Disabled by default.
EXPRESS_SERVER_ENABLED=false
EXPRESS_SERVER_PORT=8898
EXPRESS_DASHBOARD_BOT='[{"id":"bot1","name":"Local bot","reconPath":"./recon"}]'


# Combat supplies
COMBAT_MIN_GOLD=20
COMBAT_MIN_HEALTH_POTIONS=6
COMBAT_MIN_SHIELD_POTIONS=2
